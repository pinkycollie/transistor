# Thirdweb Configuration
# Get your credentials at https://thirdweb.com/dashboard/settings/api-keys
THIRDWEB_CLIENT_ID=your_client_id_here
THIRDWEB_SECRET_KEY=your_secret_key_here

# Wallet Configuration
# Export your wallet's private key for transaction signing (backend only)
WALLET_PRIVATE_KEY=0xYourPrivateKey

# Chain Configuration
# 1 = Ethereum, 137 = Polygon, 11155111 = Sepolia testnet
CHAIN_ID=11155111

# Contract Configuration
CONTRACT_ADDRESS=0xYourDAOContractAddress

# Webhook Configuration (optional)
WEBHOOK_URL=

# Server Configuration
PORT=4000
